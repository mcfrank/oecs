                "type": "strong"
              }
            ],
            "text": "Broader connections"
          }
        ]
      },
      {
        "type": "paragraph",
        "attrs": {
          "id": "npbmufugzui",
          "class": null,
          "textAlign": null,
          "rtl": null,
          "suggestionId": null,
          "suggestionTimestamp": null,
          "suggestionUserId": null,
          "suggestionDiscussionId": null,
          "suggestionKind": null,
          "suggestionOriginalAttrs": null
        },
        "content": [
          {
            "type": "text",
            "text": "Many VR researchers take inspiration from the vast literature on perceptual\u00a0 illusions.\u00a0 After all, VR tricks the mind into believing one has traveled to a new location or has swapped bodies into an avatar.\u00a0 For those looking to learn more about VR, understanding how the brain processes illusions is a great way to start.\u00a0"
          }
        ]
